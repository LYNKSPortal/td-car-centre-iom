# Database Configuration
# Get your connection string from: https://console.neon.tech
DATABASE_URL="postgresql://username:password@ep-xxx-xxx.region.aws.neon.tech/database?sslmode=require"

# NextAuth Configuration (required for admin dashboard)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars"

# Optional: Email Service (for enquiry notifications)
# RESEND_API_KEY="re_xxxxx"

# Optional: Image Upload Service
# UPLOADTHING_SECRET="sk_xxxxx"
# UPLOADTHING_APP_ID="xxxxx"
